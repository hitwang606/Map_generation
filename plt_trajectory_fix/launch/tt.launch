<launch>
  <node pkg="plt_trajectory" type="path_publisher.py" name="drone_1_marker_publisher" output="screen">
    <param name="drone_id" value="drone_1" />
    <param name="position" value="[1.0, 2.0, 3.0]" />
    <param name="color" value="[1.0, 0.0, 0.0]" />
  </node>

  <node pkg="plt_trajectory" type="path_publisher.py" name="drone_2_marker_publisher" output="screen">
    <param name="drone_id" value="drone_2" />
    <param name="position" value="[4.0, 5.0, 6.0]" />
    <param name="color" value="[0.0, 1.0, 0.0]" />
  </node>

  <node pkg="plt_trajectory" type="path_publisher.py" name="drone_3_marker_publisher" output="screen">
    <param name="drone_id" value="drone_3" />
    <param name="position" value="[7.0, 8.0, 9.0]" />
    <param name="color" value="[0.0, 0.0, 1.0]" />
  </node>
</launch>

