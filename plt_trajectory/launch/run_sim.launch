<launch>
  <arg name="drone_id"/>



  <node pkg="plt_trajectory" name="drone_$(arg drone_id)_path_publisher" type="path_publisher.py" output="screen">
    <remap from="/path" to="drone_$(arg drone_id)/path"/>
    <remap from="/odom/robot1" to="/drone_$(arg drone_id)_odom/robot1"/>
    <remap from="/odom/robot2" to="/drone_$(arg drone_id)_odom/robot2"/>
    <remap from="/odom/robot3" to="/drone_$(arg drone_id)_odom/robot3"/>
    <param name="ID" value="$(arg drone_id)"/>
  </node>

</launch>
